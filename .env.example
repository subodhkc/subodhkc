# Resend API Key (for contact form emails)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Site URL (for metadata and SEO)
NEXT_PUBLIC_SITE_URL=https://subodhkc.com

# NextAuth Configuration (if using authentication)
# NEXTAUTH_URL=https://subodhkc.com
# NEXTAUTH_SECRET=your-nextauth-secret-here

# Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_ANALYTICS_ID=your-analytics-id

# Newsletter (optional)
# NEWSLETTER_API_KEY=your-api-key

# BabyLoveGrowth API Key (for blog article sync)
# Get from Settings → Integrations → API in BabyLoveGrowth dashboard
BABYLOVE_API_KEY=your-blg-api-key-here

# BabyLoveGrowth Sync Secret (protects /api/blog-sync endpoint)
BABYLOVE_SYNC_SECRET=your-sync-secret-here

# Google Indexing API (for on-demand URL indexing)
# Get these from your GCP service account JSON key file
INDEXING_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
INDEXING_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Bearer token to protect /api/index-url endpoint (prevents quota exhaustion)
# Generate with: openssl rand -hex 32
INDEXING_API_TOKEN=your-secret-token-here

# LinkedIn OAuth (for auto-posting blog articles to LinkedIn)
# Get these from: https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
# Access token obtained via OAuth flow — expires in ~60 days
# For CI: store as GitHub secret LINKEDIN_ACCESS_TOKEN
LINKEDIN_ACCESS_TOKEN=
# LinkedIn member ID (your profile ID, needed for posting)
LINKEDIN_MEMBER_ID=
