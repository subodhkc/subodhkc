# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to Git!

# ============================================
# REQUIRED FOR PRODUCTION
# ============================================

# Resend API Key (Get from: https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Site URL (Update based on environment)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# OPTIONAL (Uncomment if needed)
# ============================================

# NextAuth Configuration
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_ANALYTICS_ID=your-analytics-id
# Plausible Analytics (set domain to enable, e.g. subodhkc.com)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=subodhkc.com

# Newsletter/Marketing
# NEWSLETTER_API_KEY=your-api-key

# BabyLoveGrowth API Key (for blog article sync)
BABYLOVE_API_KEY=your-blg-api-key-here

# BabyLoveGrowth Sync Secret (protects /api/blog-sync endpoint)
BABYLOVE_SYNC_SECRET=your-sync-secret-here

# Google Indexing API (for on-demand URL indexing)
INDEXING_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
INDEXING_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Bearer token to protect /api/index-url endpoint
INDEXING_API_TOKEN=your-secret-token-here

# LinkedIn OAuth (for auto-posting blog articles to LinkedIn)
# Get these from: https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
# Access token obtained via OAuth flow — expires in ~60 days
# For CI: store as GitHub secret LINKEDIN_ACCESS_TOKEN
LINKEDIN_ACCESS_TOKEN=
# LinkedIn member ID (your profile ID, needed for posting)
# Find at: https://www.linkedin.com/developers/apps > your app > Sign-in test
LINKEDIN_MEMBER_ID=

# Dev.to API Key (for cross-posting articles)
# Get from: https://dev.to/settings/extensions
DEVTO_API_KEY=

# ============================================
# NOTES
# ============================================
# 
# For local development:
# - NEXT_PUBLIC_SITE_URL=http://localhost:3000
# 
# For production (Vercel):
# - NEXT_PUBLIC_SITE_URL=https://subodhkc.com
# - Add all variables in Vercel Dashboard → Settings → Environment Variables
# 
# Security:
# - Never commit this file to Git
# - Keep API keys secret
# - Rotate keys periodically
